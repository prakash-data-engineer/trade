# Copy this file to .env and fill in your values. Never commit .env itself.

# Which index to track: NIFTY or BANKNIFTY
NSE_SYMBOL=NIFTY

# How many strikes above/below ATM to include in analysis
STRIKE_RANGE=10

# Telegram bot (create via @BotFather, get chat id via getUpdates - see README)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ollama (local LLM) settings
USE_OLLAMA=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# SQLite storage path
DB_PATH=data/nse_analyzer.db
